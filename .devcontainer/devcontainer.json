{
  "name": "MattSQL Ubuntu",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/MattSQL",
  "containerEnv": {
    "CMAKE_GENERATOR": "Ninja"
  },
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined"
  ],
  "mounts": [
    "source=mattsql-build-cache,target=${containerWorkspaceFolder}/build,type=volume"
  ],
  "postCreateCommand": "sudo chown -R vscode:vscode build && cmake --preset debug",
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",
        "vadimcn.vscode-lldb"
      ],
      "settings": {
        "cmake.useCMakePresets": "always",
        "cmake.configureOnOpen": false,
        "cmake.configurePreset": "debug",
        "cmake.buildPreset": "debug",
        "cmake.testPreset": "debug",
        "clangd.arguments": [
          "--compile-commands-dir=build/debug"
        ]
      }
    }
  }
}
